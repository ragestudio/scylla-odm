{
  "name": "@ragestudio/scylla-odm",
  "version": "0.22.9",
  "description": "An ODM for ScyllaDB/Cassandra",
  "license": "MIT",
  "author": "RageStudio",
  "repository": {
    "url": "https://git.ragestudio.net/ragestudio/scylla-odm"
  },
  "bugs": {
    "url": "https://git.ragestudio.net/ragestudio/scylla-odm/issues"
  },
  "keywords": [
    "scylladb",
    "cassandra",
    "odm",
    "database",
    "driver",
    "mapper",
    "typescript"
  ],
  "type": "module",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./types": {
      "types": "./types.d.ts",
      "default": "./types.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "default": "./*.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "long": "^5.3.2"
  },
  "scripts": {
    "build": "tsgo && cp package.json dist && cp README.md dist && cp -r src/driver dist/",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260619.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
