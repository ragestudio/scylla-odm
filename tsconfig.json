{
  "$schema": "http://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "ignoreDeprecations": "6.0",
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": false,
    "noImplicitAny": false,
    "types": ["node"],
    "skipLibCheck": true,
    "preserveConstEnums": true,
    "sourceMap": true,
  },
  "include": ["**/*.ts"],
}
