{
  "$schema": "http://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "baseUrl": ".",
  },
  "include": ["**/*.ts"],
}
